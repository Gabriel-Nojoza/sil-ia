      "id": "4",
      "name": "Fetch Company Catalog",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        940,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const inputItems = $input.all();\nconst rows = inputItems.flatMap((item) => {\n  if (Array.isArray(item.json)) return item.json;\n  if (Array.isArray(item.json.body)) return item.json.body;\n  return [item.json];\n});\n\nconst metrics = [...new Set(rows.filter((row) => row.artifact_type === 'measure' && row.measure_name).map((row) => row.measure_name))].sort((a, b) => a.localeCompare(b, 'pt-BR'));\nconst dimensions = [...new Set(rows.filter((row) => row.artifact_type === 'dimension' && row.table_name && row.column_name).map((row) => `${row.table_name}[${row.column_name}]`))].sort((a, b) => a.localeCompare(b, 'pt-BR'));\nconst tables = [...new Set(rows.filter((row) => row.table_name).map((row) => row.table_name))].sort((a, b) => a.localeCompare(b, 'pt-BR'));\n\nreturn [{\n  json: {\n    company_id: $('Normalize Request').first().json.company_id,\n    workspace_id: $('Normalize Request').first().json.workspace_id,\n    dataset_id: $('Normalize Request').first().json.dataset_id,\n    default_period: 'mes_atual',\n    allowed_metrics: metrics,\n    allowed_dimensions: dimensions,\n    catalog_loaded: true,\n    tables,\n    summary: {\n      total_rows: rows.length,\n      total_metrics: metrics.length,\n      total_dimensions: dimensions.length,\n      total_tables: tables.length\n    }\n  }\n}];"
      },
      "id": "5",
      "name": "Aggregate Catalog",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1180,
        300
      ]
    },

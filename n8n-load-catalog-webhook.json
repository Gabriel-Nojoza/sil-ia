    {
      "parameters": {
        "method": "GET",
        "url": "=https://YOUR_PROJECT.supabase.co/rest/v1/company_catalog?company_id=eq.{{$json.company_id}}&select=*",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "YOUR_SUPABASE_SERVICE_ROLE_KEY"
            },
            {
              "name": "Authorization",
              "value": "Bearer YOUR_SUPABASE_SERVICE_ROLE_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "options": {
          "ignoreResponseCode": false
        }

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Database (Postgres / Supabase)
DATABASE_HOST=db.seu-projeto.supabase.co
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=sua-senha-do-banco
DATABASE_SSL=true

# Groq
GROQ_API_KEY=gsk_...sua-chave-aqui
GROQ_MODEL=llama-3.1-8b-instant

# Power BI / Microsoft Entra ID
POWERBI_TENANT_ID=seu-tenant-id
POWERBI_CLIENT_ID=seu-client-id
POWERBI_CLIENT_SECRET=seu-client-secret
POWERBI_DATASET_ID=seu-dataset-id
POWERBI_WORKSPACE_ID=seu-workspace-id
